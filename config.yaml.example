# 微信聊天摘要工具 - 配置文件模板
# 复制此文件为 config.yaml，然后根据实际情况修改

# ── 基础配置 ────────────────────────────────────────────────────────────────

# wechat-cli 命令或完整路径（确保 wechat-cli 已安装且在 PATH 中）
wechat_cli: "wechat-cli"

# 摘要输出目录
output_dir: "summaries"

# 摘要统计时段（小时，例如 24 表示过去 24 小时）
summary_hours: 24

# 摘要模式: "rule"(规则模式，快速，无需额外依赖) 或 "ollama"(AI模式，需要安装 Ollama）
summary_mode: "rule"

# Ollama 模型名称（summary_mode=ollama 时使用）
ollama_model: "qwen2:7b"

# 每个群最多拉取的消息条数
max_messages_per_group: 500

# ── 群聊监控模式 ────────────────────────────────────────────────────────────
# discover:  自动发现（推荐）— 扫描所有群聊，识别与核心联系人共同存在的群聊并监控
#            （解释：你指定了张三和李四，脚本会找出所有包含张三或李四的群）
# all:       监控所有群聊（消息量可能很大）
# specific:  只监控下面 groups 列表中指定的群
group_monitor_mode: "discover"

# 指定监控的群名（group_monitor_mode=specific 时使用）
# 示例: ["工作群A", "项目群B"]
groups: []

# ── 核心联系人 ────────────────────────────────────────────────────────────────
# 用途：
#   1) group_monitor_mode=discover 时，自动发现包含这些联系人的群
#   2) private_chat_mode=core 时，监控这些联系人的私聊
#
# name:     显示名称（用于输出摘要时的标注）
# aliases:   精确匹配用别名（避免子串误匹配，例如备注名、昵称变体）
#
# 【首次使用请通过 --setup 向导配置，或手动编辑此文件】
core_contacts: []

# ── 私聊监控模式 ──────────────────────────────────────────────────────────────
# core:     监控核心联系人的私聊（private_chat_mode=core 时使用 core_contacts）
# specific: 监控下面 private_contacts 中指定的联系人
# all:      监控所有私聊（消息量可能很大，谨慎使用）
private_chat_mode: "core"

# 指定监控的联系人（private_chat_mode=specific 时使用）
# 示例: ["张三", "李四"]
private_contacts: []

# ── 排除关键词 ────────────────────────────────────────────────────────────────
# 群名包含以下关键词的不纳入监控（购物、生活类群）
# 可根据需要增删
exclude_keywords:
  - "好物"
  - "分享群"
  - "种草"
  - "拼拼"
  - "闲置"
  - "二手"
  - "购物"
  - "团购"
  - "优惠券"
  - "红包"
  - "外卖"
  - "宠物"
  - "撸猫"
  - "遛狗"
  - "游戏"
  - "开黑"
  - "相亲"
  - "交友"
  - "八卦"

# ── 项目跟进配置（可选）────────────────────────────────────────────────────────
# enabled: true 时启用项目跟进报告功能
# projects: 项目列表，每个项目包含：
#   name:       项目名称
#   keywords:   关键词列表（用于检索相关消息）
#   related_groups: 相关群名列表（优先在这些群里搜索）
#
# 【可选】不需要可以保持 enabled: false
project_tracking:
  enabled: false
  projects: []
